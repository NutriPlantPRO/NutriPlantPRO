{
  "openapi": "3.1.0",
  "info": {
    "title": "NutriPlant Admin Assistant",
    "version": "2.0.0",
    "description": "Lectura NutriPlant (proyectos, lab, manual). Plan PRO personal: lectura y escritura (create/update) solo cerebro digital admin."
  },
  "servers": [
    {
      "url": "https://nutriplantpro.com"
    }
  ],
  "paths": {
    "/api/admin-assistant": {
      "post": {
        "operationId": "nutriplantAdminQuery",
        "summary": "Consulta NutriPlant y Plan PRO (lectura + crear/editar apuntes)",
        "description": "NutriPlant: project_analyses, manual_tecnico_catalog, etc. Plan PRO (solo Jesús): plan_pro_day, plan_pro_week, plan_pro_create, plan_pro_update. Nunca inventar datos de clientes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Respuesta JSON con ok y datos"
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "schemas": {
      "AdminRequest": {
        "type": "object",
        "required": ["action", "params"],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "admin_stats",
              "list_users",
              "user_summary",
              "search_projects",
              "project_detail",
              "project_analyses",
              "project_vpd_live",
              "project_climate",
              "plan_pro_catalog",
              "plan_pro_day",
              "plan_pro_week",
              "plan_pro_search",
              "plan_pro_item",
              "plan_pro_create",
              "plan_pro_update",
              "radar_project",
              "radar_search",
              "radar_overview",
              "free_tools_catalog",
              "lab_analyses_catalog",
              "manual_tecnico_catalog",
              "describe_api"
            ]
          },
          "params": {
            "type": "object",
            "description": "Parámetros según action.",
            "properties": {
              "project_id": { "type": "string" },
              "project_name": { "type": "string" },
              "type": {
                "type": "string",
                "description": "project_analyses: suelo|solucion_nutritiva|extracto_pasta|agua|foliar|fruta|all"
              },
              "mode": { "type": "string", "description": "project_climate: saved|live|rainfall_refresh|all" },
              "email": { "type": "string" },
              "crop": { "type": "string" },
              "q": { "type": "string", "description": "Búsqueda o título de apunte Plan PRO" },
              "item_id": { "type": "string", "description": "UUID apunte Plan PRO" },
              "title": { "type": "string", "description": "plan_pro_create/update: título" },
              "note": { "type": "string", "description": "plan_pro_create/update: nota (body_plain)" },
              "body_plain": { "type": "string" },
              "priority": { "type": "string", "description": "alta|media|baja o Alta|Media|Baja" },
              "due_at": { "type": "string", "description": "YYYY-MM-DD fecha objetivo" },
              "due_on": { "type": "string", "description": "plan_pro_day: YYYY-MM-DD" },
              "due_date": { "type": "string" },
              "area_id": { "type": "string" },
              "area_slug": { "type": "string" },
              "area_title": { "type": "string" },
              "category_id": { "type": "string" },
              "category_title": { "type": "string" },
              "next_action": { "type": "string" },
              "status": { "type": "string" },
              "thought_type": { "type": "string" },
              "relation_tags": { "type": "string", "description": "tags separados por coma" },
              "tags": { "type": "string" },
              "close": { "type": "boolean", "description": "plan_pro_update: marcar cerrado" },
              "reopen": { "type": "boolean" },
              "append_note": { "type": "string", "description": "plan_pro_update: añadir texto a nota" },
              "days_ahead": { "type": "integer" },
              "include_overdue": { "type": "boolean" },
              "limit": { "type": "integer" },
              "tool_id": { "type": "string" },
              "tab_id": { "type": "string" },
              "report_id": { "type": "string" },
              "latest_only": { "type": "boolean" },
              "chapter_id": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
